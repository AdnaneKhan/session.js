{
	"name": "@session.js/calls",
	"version": "0.1.0",
	"description": "Headless 1:1 voice calls for session.js (Session-to-Session VoIP, WebRTC/Opus). AGPL-3.0-or-later.",
	"license": "AGPL-3.0-or-later",
	"type": "module",
	"main": "dist/index.js",
	"types": "dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"default": "./dist/index.js"
		}
	},
	"files": [
		"dist",
		"README.md",
		"LICENSE",
		"COPYING.provenance"
	],
	"engines": {
		"node": ">=22"
	},
	"scripts": {
		"build": "tsc -p tsconfig.json && tsc -p tsconfig.examples.json",
		"test": "bun test",
		"example:echo": "bun examples/offline-echo.ts",
		"example:agent": "bun examples/voice-agent.ts",
		"spike": "bun spike/werift-loopback.ts",
		"spike:turn": "bun spike/turn-connectivity.ts"
	},
	"dependencies": {
		"werift": "0.23.0"
	},
	"optionalDependencies": {
		"@discordjs/opus": "0.10.0"
	},
	"peerDependencies": {
		"@session.js/client": ">=0.0.57"
	}
}
