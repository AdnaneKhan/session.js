{
	"compilerOptions": {
		// Enable latest features
		"lib": ["ESNext", "DOM"],
		"target": "ESNext",
		"module": "ESNext",
		"moduleDetection": "force",
		"jsx": "react-jsx",
		"allowJs": true,
		"declaration": true,

		// Bundler mode
		"moduleResolution": "bundler",
		"verbatimModuleSyntax": true,
		// Default-import CJS packages (lodash) — Node's ESM interop hands us
		// module.exports as `default`; named imports from CJS are unreliable.
		"esModuleInterop": true,

		// Best practices
		"strict": true,
		"skipLibCheck": true,
		"noFallthroughCasesInSwitch": true,

		// Some stricter flags (disabled by default)
		"noUnusedLocals": false,
		"noUnusedParameters": false,
		"noPropertyAccessFromIndexSignature": false,
		"baseUrl": ".",
		"paths": {
			"@/*": ["src/*"]
		},
		"outDir": "./dist"
	},
	"include": ["src/**/*.ts"]
}
